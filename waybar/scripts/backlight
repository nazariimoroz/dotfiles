#!/usr/bin/env bash
#
# Adjust screen brightness and send a notification with the current level
#
# Requires brightnessctl
#
# Author:  Jesse Mirabel <sejjymvm@gmail.com>
# Date:    August 28, 2025
# License: MIT

DEF_VALUE=1

# Resolve the backlight device that actually drives the active panel.
#
# A machine can expose several backlight devices (e.g. an inert dGPU
# "nvidia_0" alongside the real "intel_backlight"/"amdgpu_bl0"). Pick the
# one whose DRM connector is a connected + enabled internal panel, so this
# works regardless of GPU vendor. Falls back to the device with the largest
# max_brightness (waybar's own heuristic), then to brightnessctl's default.
detect_device() {
	local bl dev conn fallback="" fallback_max=-1 max

	for bl in /sys/class/backlight/*; do
		[ -e "$bl/device" ] || continue
		dev=$(readlink -f "$bl/device") || continue

		# The device link may point straight at the connector, or at the
		# GPU that owns it; check both for an internal panel (eDP/LVDS/DSI).
		for conn in "$dev" "$dev"/drm/*/*-eDP-* "$dev"/drm/*/*-LVDS-* "$dev"/drm/*/*-DSI-*; do
			[ -e "$conn/enabled" ] || continue
			[ "$(cat "$conn/enabled")" = enabled ]   || continue
			[ "$(cat "$conn/status")" = connected ]  || continue
			printf '%s\n' "${bl##*/}"
			return 0
		done

		max=$(cat "$bl/max_brightness" 2>/dev/null) || max=-1
		if ((max > fallback_max)); then
			fallback_max=$max
			fallback=${bl##*/}
		fi
	done

	[ -n "$fallback" ] && printf '%s\n' "$fallback"
}

usage() {
	local script=${0##*/}

	cat <<- EOF
		USAGE: $script {up|down} [value]

		Adjust screen brightness and send a notification with the current level

		OPTIONS:
		  up   [value]    Increase brightness by [value] (default: $DEF_VALUE)
		  down [value]    Decrease brightness by [value] (default: $DEF_VALUE)

		EXAMPLES:
		  Increase brightness:
		    $ $script up

		  Decrease brightness by 5:
		    $ $script down 5
	EOF
}

main() {
	local action=$1
	local value=${2:-$DEF_VALUE}

	if ((value < 1)); then
		usage >&2
		return 1
	fi

	case $action in
		up | down)
			local sign

			case $action in
				up)   sign='+' ;;
				down) sign='-' ;;
			esac

			local device
			device=$(detect_device)

			brightnessctl ${device:+-d "$device"} -n set "${value}%${sign}" > /dev/null

			local level
			level=$(brightnessctl ${device:+-d "$device"} -m | awk -F ',' '{print $4}')

			notify-send "Brightness: $level" -h int:value:"$level" -i \
				"contrast" -h string:x-canonical-private-synchronous:backlight
			;;
		*)
			usage >&2
			return 1
			;;
	esac
}

main "$@"
